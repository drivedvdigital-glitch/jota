# Configurações do Extrator de Produtos
GEMINI_API_KEY=sua_chave_de_api_do_gemini_aqui
PORT=8000
HOST=127.0.0.1

# --- CREDENCIAIS COLÔMBIA ---
SHOPIFY_SHOP_NAME_COLOMBIA=seu-shop-colombia-slug
SHOPIFY_ACCESS_TOKEN_COLOMBIA=shpat_token_colombia
# Caso o app tenha sido criado após 2026:
SHOPIFY_CLIENT_ID_COLOMBIA=seu_client_id_colombia

# --- CREDENCIAIS ROMÊNIA ---
SHOPIFY_SHOP_NAME_ROMANIA=seu-shop-romenia-slug
SHOPIFY_ACCESS_TOKEN_ROMANIA=shpat_token_romenia
# Caso o app tenha sido criado após 2026:
SHOPIFY_CLIENT_ID_ROMANIA=seu_client_id_romenia

# --- CONFIGURAÇÃO PADRÃO / FALLBACK (Legada) ---
SHOPIFY_SHOP_NAME=sua-loja-shopify-slug
SHOPIFY_ACCESS_TOKEN=shpat_seu_access_token_aqui
SHOPIFY_CLIENT_ID=
